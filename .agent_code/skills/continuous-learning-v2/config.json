{
  "version": "2.1",
  "observation": {
    "enabled": true,
    "store_path": "${CONTINUOUS_LEARNING_HOME}/observations.jsonl",
    "max_file_size_mb": 10,
    "archive_after_days": 7,
    "capture_tools": ["Edit", "Write", "Bash", "Read", "Grep", "Glob"],
    "ignore_tools": ["TodoWrite"]
  },
  "instincts": {
    "personal_path": "${CONTINUOUS_LEARNING_HOME}/instincts/personal/",
    "inherited_path": "${CONTINUOUS_LEARNING_HOME}/instincts/inherited/",
    "min_confidence": 0.3,
    "auto_approve_threshold": 0.7,
    "confidence_decay_rate": 0.02,
    "max_instincts": 100
  },
  "observer": {
    "enabled": false,
    "run_interval_minutes": 5,
    "min_observations_to_analyze": 20,
    "patterns_to_detect": [
      "user_corrections",
      "error_resolutions",
      "repeated_workflows",
      "tool_preferences",
      "file_patterns"
    ]
  },
  "evolution": {
    "evolved_path": "${CONTINUOUS_LEARNING_HOME}/evolved/",
    "auto_evolve": false
  }
}
